            "pages": [
              "configuration/tsconfig",
              "configuration/compiler-options",
              "configuration/project-references",
              "configuration/module-resolution"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/migrating-from-javascript",
              "guides/declaration-files",
              "guides/jsx",
