  "theme": "linden",
  "colors": {
    "primary": "#040404",
    "light": "#007ACC",
    "dark": "#007ACC"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://media.brand.dev/efaa462a-7e44-486c-a3fb-f587e0d18823.svg",
